#!/usr/bin/env bash
# PhD Hub CLI — manage your PhD Hub from the command line
# Usage: phd <command> [subcommand] [options]

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TASKS_DIR="$REPO_ROOT/tasks"
RESEARCH_DIR="$REPO_ROOT/research"
PAPERS_DIR="$REPO_ROOT/papers"
DISSERTATION_DIR="$REPO_ROOT/dissertation"
CAREER_DIR="$REPO_ROOT/career"

# ── Colours ────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

print_header() {
  echo -e "${BOLD}${BLUE}┌─ PhD Hub ────────────────────────────────────┐${NC}"
}
print_footer() {
  echo -e "${BOLD}${BLUE}└──────────────────────────────────────────────┘${NC}"
}
err()  { echo -e "${RED}Error:${NC} $*" >&2; exit 1; }
ok()   { echo -e "${GREEN}✓${NC} $*"; }
info() { echo -e "  $*"; }

# ── Helpers ─────────────────────────────────────────────────────────────────
slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g; s/-\+/-/g; s/^-//; s/-$//'
}

today() { date +%Y-%m-%d; }

# Read a YAML frontmatter field from a file
# Usage: fmget <field> <file>
fmget() {
  grep "^${1}:" "$2" 2>/dev/null | head -1 | sed "s/^${1}: *//"
}

# ── Tasks ────────────────────────────────────────────────────────────────────
task_add() {
  local title="" priority="medium" status="not-started"
  local due="" chapter="" collaborator="" access=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --priority)    priority="$2";    shift 2 ;;
      --status)      status="$2";      shift 2 ;;
      --due)         due="$2";         shift 2 ;;
      --chapter)     chapter="$2";     shift 2 ;;
      --collaborator) collaborator="$2"; shift 2 ;;
      --access)      access="$2";      shift 2 ;;
      --) shift; title="$*"; break ;;
      -*) err "Unknown option: $1" ;;
      *)  [[ -z "$title" ]] && title="$1"; shift ;;
    esac
  done

  [[ -z "$title" ]] && err "Task title is required.\nUsage: phd task add \"Title\" [--priority high|medium|low] [--status not-started|in-progress|done|blocked] [--due YYYY-MM-DD] [--chapter \"...\"] [--collaborator \"...\"]"

  local slug; slug=$(slugify "$title")
  local file="$TASKS_DIR/${slug}.md"
  [[ -f "$file" ]] && err "Task '${title}' already exists (${slug}.md). Use 'phd task update' to modify it."

  cat > "$file" <<EOF
---
title: ${title}
priority: ${priority}
status: ${status}
due: ${due}
chapter: ${chapter}
collaborator: ${collaborator}
access: ${access}
created: $(today)
---

## Notes

EOF

  ok "Task added: ${BOLD}${title}${NC}"
  info "File : tasks/${slug}.md"
  info "Due  : ${due:-—}  |  Priority: ${priority}  |  Status: ${status}"
  _sync_tasks
}

task_list() {
  local fs="" fp=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)   fs="$2"; shift 2 ;;
      --priority) fp="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  print_header
  echo -e "  ${BOLD}Tasks${NC}"
  echo ""
  local count=0
  for file in "$TASKS_DIR"/*.md; do
    [[ "$(basename "$file")" == "_index.md" ]] && continue
    [[ ! -f "$file" ]] && continue

    local t; t=$(fmget title "$file")
    local p; p=$(fmget priority "$file")
    local s; s=$(fmget status "$file")
    local d; d=$(fmget due "$file")
    local c; c=$(fmget chapter "$file")

    [[ -n "$fs" && "$s" != "$fs" ]] && continue
    [[ -n "$fp" && "$p" != "$fp" ]] && continue

    local sc=$NC pc=$NC
    if   [[ "$s" == "in-progress" ]]; then sc=$YELLOW
    elif [[ "$s" == "done"        ]]; then sc=$GREEN
    elif [[ "$s" == "blocked"     ]]; then sc=$RED
    fi
    if   [[ "$p" == "high"   ]]; then pc=$RED
    elif [[ "$p" == "medium" ]]; then pc=$YELLOW
    elif [[ "$p" == "low"    ]]; then pc=$GREEN
    fi

    echo -e "  ${BOLD}${t}${NC}"
    echo -e "    Priority: ${pc}${p}${NC}  |  Status: ${sc}${s}${NC}"
    [[ -n "$d" ]] && info "Due     : ${d}"
    [[ -n "$c" ]] && info "Chapter : ${c}"
    echo ""
    count=$((count + 1))
  done
  [[ $count -eq 0 ]] && info "${CYAN}No tasks found.${NC}"
  print_footer
  echo -e "  Total: ${count} task(s)"
}

task_update() {
  local search="$1"; shift
  local slug; slug=$(slugify "$search")
  local file="$TASKS_DIR/${slug}.md"
  [[ ! -f "$file" ]] && err "Task '${search}' not found (looked for tasks/${slug}.md)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --priority)
        sed -i "s/^priority: .*/priority: $2/" "$file"
        ok "Priority → $2"; shift 2 ;;
      --status)
        sed -i "s/^status: .*/status: $2/" "$file"
        ok "Status → $2"; shift 2 ;;
      --due)
        sed -i "s/^due: .*/due: $2/" "$file"
        ok "Due date → $2"; shift 2 ;;
      --chapter)
        sed -i "s/^chapter: .*/chapter: $2/" "$file"
        ok "Chapter → $2"; shift 2 ;;
      --collaborator)
        sed -i "s/^collaborator: .*/collaborator: $2/" "$file"
        ok "Collaborator → $2"; shift 2 ;;
      --title)
        local nt="$2"
        sed -i "s/^title: .*/title: $nt/" "$file"
        local ns; ns=$(slugify "$nt")
        mv "$file" "$TASKS_DIR/${ns}.md"
        ok "Title → $nt (renamed to ${ns}.md)"; shift 2 ;;
      *) shift ;;
    esac
  done
  _sync_tasks
}

task_done() {
  task_update "$1" --status "done"
  ok "Task marked as done!"
}

task_show() {
  local slug; slug=$(slugify "$1")
  local file="$TASKS_DIR/${slug}.md"
  [[ ! -f "$file" ]] && err "Task '$1' not found"
  cat "$file"
}

task_rm() {
  local slug; slug=$(slugify "$1")
  local file="$TASKS_DIR/${slug}.md"
  [[ ! -f "$file" ]] && err "Task '$1' not found"
  rm "$file"
  ok "Task removed: $1"
  _sync_tasks
}

_sync_tasks() {
  local index="$TASKS_DIR/_index.md"
  {
    echo "# Tasks"
    echo ""
    echo "> Auto-generated index. Use \`phd task list\` to view tasks, \`phd task add\` to add new ones."
    echo ""
    echo "| Title | Priority | Status | Due | Chapter |"
    echo "|-------|----------|--------|-----|---------|"
    for file in "$TASKS_DIR"/*.md; do
      [[ "$(basename "$file")" == "_index.md" ]] && continue
      [[ ! -f "$file" ]] && continue
      local t p s d c slug_base
      t=$(fmget title "$file"); p=$(fmget priority "$file")
      s=$(fmget status "$file"); d=$(fmget due "$file")
      c=$(fmget chapter "$file"); slug_base=$(basename "$file" .md)
      echo "| [${t}](./${slug_base}.md) | ${p} | ${s} | ${d} | ${c} |"
    done
  } > "$index"
}

# ── Notes ────────────────────────────────────────────────────────────────────
note_add() {
  local title="" date; date=$(today)
  local type="meeting" content=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)   title="$2";   shift 2 ;;
      --date)    date="$2";    shift 2 ;;
      --type)    type="$2";    shift 2 ;;
      --content) content="$2"; shift 2 ;;
      -*) err "Unknown option: $1" ;;
      *)  [[ -z "$title" ]] && title="$1"; shift ;;
    esac
  done

  [[ -z "$title" ]] && err "Note title is required.\nUsage: phd note add \"Title\" [--date YYYY-MM-DD] [--type meeting|seminar|other]"

  local notes_dir="$RESEARCH_DIR/meeting-seminar-notes"
  local slug; slug=$(slugify "$title")
  local file="$notes_dir/${date}-${slug}.md"

  cat > "$file" <<EOF
---
title: ${title}
date: ${date}
type: ${type}
---

# ${title}

**Date:** ${date}
**Type:** ${type}

## Summary

${content}

## Key Takeaways

-

## Action Items

- [ ]

## Attendees / Speaker

-
EOF

  ok "Note added: ${BOLD}${title}${NC}"
  info "File: research/meeting-seminar-notes/${date}-${slug}.md"
  _sync_notes
}

note_list() {
  local notes_dir="$RESEARCH_DIR/meeting-seminar-notes"
  print_header
  echo -e "  ${BOLD}Meeting & Seminar Notes${NC}"
  echo ""
  local count=0
  for file in "$notes_dir"/*.md; do
    [[ "$(basename "$file")" == "_index.md" ]] && continue
    [[ ! -f "$file" ]] && continue
    local t; t=$(fmget title "$file")
    local d; d=$(fmget date "$file")
    local y; y=$(fmget type "$file")
    echo -e "  ${BOLD}${t}${NC}"
    info "Date: ${d}  |  Type: ${CYAN}${y}${NC}"
    echo ""
    count=$((count + 1))
  done
  [[ $count -eq 0 ]] && info "${CYAN}No notes found.${NC}"
  print_footer
}

_sync_notes() {
  local notes_dir="$RESEARCH_DIR/meeting-seminar-notes"
  local index="$notes_dir/_index.md"
  {
    echo "# Meeting & Seminar Notes"
    echo ""
    echo "> Auto-generated index. Use \`phd note list\` to view, \`phd note add\` to add."
    echo ""
    echo "| Title | Date | Type |"
    echo "|-------|------|------|"
    for file in "$notes_dir"/*.md; do
      [[ "$(basename "$file")" == "_index.md" ]] && continue
      [[ ! -f "$file" ]] && continue
      local t d y slug_base
      t=$(fmget title "$file"); d=$(fmget date "$file")
      y=$(fmget type "$file"); slug_base=$(basename "$file" .md)
      echo "| [${t}](./${slug_base}.md) | ${d} | ${y} |"
    done
  } > "$index"
}

# ── Literature ───────────────────────────────────────────────────────────────
lit_add() {
  local title="" authors="" year="" journal="" url="" paper="" notes=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)   title="$2";   shift 2 ;;
      --authors) authors="$2"; shift 2 ;;
      --year)    year="$2";    shift 2 ;;
      --journal) journal="$2"; shift 2 ;;
      --url)     url="$2";     shift 2 ;;
      --paper)   paper="$2";   shift 2 ;;
      --notes)   notes="$2";   shift 2 ;;
      -*) err "Unknown option: $1" ;;
      *)  [[ -z "$title" ]] && title="$1"; shift ;;
    esac
  done

  [[ -z "$title" ]] && err "Paper title is required.\nUsage: phd lit add \"Title\" [--authors \"...\"] [--year YYYY] [--journal \"...\"] [--url \"...\"]"

  local lit_dir="$RESEARCH_DIR/literature-notes"
  local slug; slug=$(slugify "$title")
  local file="$lit_dir/${slug}.md"

  cat > "$file" <<EOF
---
title: ${title}
authors: ${authors}
year: ${year}
journal: ${journal}
url: ${url}
paper: ${paper}
added: $(today)
status: unread
---

# ${title}

**Authors:** ${authors}
**Year:** ${year}
**Journal:** ${journal}
**URL:** ${url}

## Summary

${notes}

## Key Points

-

## Relevance to My Work

-

## Quotes

>
EOF

  ok "Literature note added: ${BOLD}${title}${NC}"
  info "File: research/literature-notes/${slug}.md"
  _sync_lit
}

lit_list() {
  local lit_dir="$RESEARCH_DIR/literature-notes"
  print_header
  echo -e "  ${BOLD}Literature Notes${NC}"
  echo ""
  local count=0
  for file in "$lit_dir"/*.md; do
    [[ "$(basename "$file")" == "_index.md" ]] && continue
    [[ ! -f "$file" ]] && continue
    local t a y s
    t=$(fmget title "$file"); a=$(fmget authors "$file")
    y=$(fmget year "$file");  s=$(fmget status "$file")
    local sc=$YELLOW; [[ "$s" == "read" ]] && sc=$GREEN
    echo -e "  ${BOLD}${t}${NC} (${y})"
    info "Authors: ${a}"
    info "Status : ${sc}${s}${NC}"
    echo ""
    count=$((count + 1))
  done
  [[ $count -eq 0 ]] && info "${CYAN}No literature notes found.${NC}"
  print_footer
}

lit_update() {
  local search="$1"; shift
  local slug; slug=$(slugify "$search")
  local file="$RESEARCH_DIR/literature-notes/${slug}.md"
  [[ ! -f "$file" ]] && err "Literature note '${search}' not found"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)  sed -i "s/^status: .*/status: $2/"  "$file"; ok "Status → $2"; shift 2 ;;
      --journal) sed -i "s/^journal: .*/journal: $2/" "$file"; ok "Journal → $2"; shift 2 ;;
      *) shift ;;
    esac
  done
}

_sync_lit() {
  local lit_dir="$RESEARCH_DIR/literature-notes"
  local index="$lit_dir/_index.md"
  {
    echo "# Literature Notes"
    echo ""
    echo "> Auto-generated index. Use \`phd lit list\` to view, \`phd lit add\` to add."
    echo ""
    echo "| Title | Authors | Year | Status |"
    echo "|-------|---------|------|--------|"
    for file in "$lit_dir"/*.md; do
      [[ "$(basename "$file")" == "_index.md" ]] && continue
      [[ ! -f "$file" ]] && continue
      local t a y s slug_base
      t=$(fmget title "$file"); a=$(fmget authors "$file")
      y=$(fmget year "$file");  s=$(fmget status "$file")
      slug_base=$(basename "$file" .md)
      echo "| [${t}](./${slug_base}.md) | ${a} | ${y} | ${s} |"
    done
  } > "$index"
}

# ── Papers ───────────────────────────────────────────────────────────────────
paper_list() {
  print_header
  echo -e "  ${BOLD}Papers${NC}"
  echo ""
  for file in "$PAPERS_DIR"/*.md; do
    [[ "$(basename "$file")" == *"overview"* ]] && continue
    [[ ! -f "$file" ]] && continue
    local t s j
    t=$(fmget title "$file"); s=$(fmget status "$file"); j=$(fmget target-journal "$file")
    echo -e "  ${BOLD}${t}${NC}"
    [[ -n "$s" ]] && info "Status : ${CYAN}${s}${NC}"
    [[ -n "$j" ]] && info "Journal: ${j}"
    echo ""
  done
  print_footer
}

paper_update() {
  local paper="$1"; shift
  local file="$PAPERS_DIR/${paper}.md"
  [[ ! -f "$file" ]] && {
    echo -e "${RED}Error:${NC} Paper '${paper}' not found. Available papers:"
    ls "$PAPERS_DIR"/*.md 2>/dev/null | xargs -I{} basename {} .md | grep -v "overview"
    exit 1
  }
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)   sed -i "s/^status: .*/status: $2/"               "$file"; ok "Status → $2";   shift 2 ;;
      --journal)  sed -i "s/^target-journal: .*/target-journal: $2/" "$file"; ok "Journal → $2";  shift 2 ;;
      --deadline) sed -i "s/^deadline: .*/deadline: $2/"            "$file"; ok "Deadline → $2"; shift 2 ;;
      *) shift ;;
    esac
  done
}

# ── Chapters ─────────────────────────────────────────────────────────────────
chapter_update() {
  local chapter="$1"; shift
  local file="$DISSERTATION_DIR/${chapter}.md"
  [[ ! -f "$file" ]] && {
    echo -e "${RED}Error:${NC} Chapter '${chapter}' not found. Available:"
    ls "$DISSERTATION_DIR"/*.md 2>/dev/null | xargs -I{} basename {} .md | grep -v "overview"
    exit 1
  }
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)   sed -i "s/^status: .*/status: $2/"   "$file"; ok "Status → $2";   shift 2 ;;
      --deadline) sed -i "s/^deadline: .*/deadline: $2/" "$file"; ok "Deadline → $2"; shift 2 ;;
      *) shift ;;
    esac
  done
}

# ── Calendar ─────────────────────────────────────────────────────────────────
calendar_show() {
  print_header
  echo -e "  ${BOLD}Upcoming Deadlines${NC}"
  echo ""
  local today; today=$(today)
  local found=0
  while IFS= read -r line; do
    echo -e "  $line"
    found=1
  done < <(
    for file in "$TASKS_DIR"/*.md; do
      [[ "$(basename "$file")" == "_index.md" ]] && continue
      [[ ! -f "$file" ]] && continue
      local due; due=$(fmget due "$file")
      [[ -z "$due" ]] && continue
      local s; s=$(fmget status "$file")
      [[ "$s" == "done" ]] && continue
      local t; t=$(fmget title "$file")
      local p; p=$(fmget priority "$file")
      local pc=$NC
      case "$p" in high) pc=$RED ;; medium) pc=$YELLOW ;; low) pc=$GREEN ;; esac
      echo "${due}  ${pc}[${p}]${NC}  ${t}"
    done | sort
  )
  [[ $found -eq 0 ]] && info "${CYAN}No upcoming deadlines.${NC}"
  print_footer
}

# ── Sync all indices ──────────────────────────────────────────────────────────
sync_all() {
  echo -e "${BLUE}Syncing all indices...${NC}"
  _sync_tasks
  [[ -d "$RESEARCH_DIR/meeting-seminar-notes" ]] && _sync_notes || true
  [[ -d "$RESEARCH_DIR/literature-notes" ]] && _sync_lit || true
  ok "All indices synced"
}

# ── Commit & push ─────────────────────────────────────────────────────────────
push_changes() {
  local msg="${1:-"chore: update PhD Hub content [$(today)]"}"
  cd "$REPO_ROOT"
  git add -A
  git commit -m "$msg" || { echo -e "${YELLOW}Nothing to commit.${NC}"; return 0; }
  git push -u origin HEAD
  ok "Changes committed and pushed"
}

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
  print_header
  echo ""
  echo -e "  ${BOLD}USAGE${NC}  phd <command> [subcommand] [options]"
  echo ""
  echo -e "  ${BOLD}TASK COMMANDS${NC}"
  echo -e "    ${CYAN}phd task add${NC}    \"Title\" [--priority high|medium|low]"
  echo -e "                    [--status not-started|in-progress|done|blocked]"
  echo -e "                    [--due YYYY-MM-DD] [--chapter \"...\"] [--collaborator \"...\"]"
  echo -e "    ${CYAN}phd task list${NC}   [--status <s>] [--priority <p>]"
  echo -e "    ${CYAN}phd task update${NC} \"Title\" [--priority|--status|--due|--chapter|--title ...]"
  echo -e "    ${CYAN}phd task done${NC}   \"Title\""
  echo -e "    ${CYAN}phd task show${NC}   \"Title\""
  echo -e "    ${CYAN}phd task rm${NC}     \"Title\""
  echo ""
  echo -e "  ${BOLD}NOTE COMMANDS${NC}"
  echo -e "    ${CYAN}phd note add${NC}    \"Title\" [--date YYYY-MM-DD] [--type meeting|seminar|other]"
  echo -e "    ${CYAN}phd note list${NC}"
  echo ""
  echo -e "  ${BOLD}LITERATURE COMMANDS${NC}"
  echo -e "    ${CYAN}phd lit add${NC}     \"Title\" [--authors \"...\"] [--year YYYY] [--journal \"...\"] [--url \"...\"]"
  echo -e "    ${CYAN}phd lit list${NC}"
  echo -e "    ${CYAN}phd lit update${NC}  \"Title\" [--status read|unread] [--journal \"...\"]"
  echo ""
  echo -e "  ${BOLD}PAPER COMMANDS${NC}"
  echo -e "    ${CYAN}phd paper list${NC}"
  echo -e "    ${CYAN}phd paper update${NC} paper-1 [--status \"...\"] [--journal \"...\"] [--deadline YYYY-MM-DD]"
  echo ""
  echo -e "  ${BOLD}CHAPTER COMMANDS${NC}"
  echo -e "    ${CYAN}phd chapter update${NC} chapter-1-lit-review [--status \"...\"] [--deadline YYYY-MM-DD]"
  echo ""
  echo -e "  ${BOLD}OTHER${NC}"
  echo -e "    ${CYAN}phd calendar${NC}          Show upcoming deadlines"
  echo -e "    ${CYAN}phd sync${NC}              Regenerate all index files"
  echo -e "    ${CYAN}phd push${NC} [\"message\"]  Commit and push all changes"
  echo -e "    ${CYAN}phd help${NC}              Show this help"
  echo ""
  print_footer
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
case "${1:-}" in
  task)
    case "${2:-}" in
      add)    shift 2; task_add    "$@" ;;
      list)   shift 2; task_list   "$@" ;;
      update) shift 2; task_update "$@" ;;
      done)   shift 2; task_done   "$@" ;;
      show)   shift 2; task_show   "$@" ;;
      rm)     shift 2; task_rm     "$@" ;;
      *) err "Unknown task subcommand: '${2:-}'\nRun 'phd help' for usage." ;;
    esac ;;
  note)
    case "${2:-}" in
      add)  shift 2; note_add  "$@" ;;
      list) shift 2; note_list "$@" ;;
      *) err "Unknown note subcommand: '${2:-}'" ;;
    esac ;;
  lit)
    case "${2:-}" in
      add)    shift 2; lit_add    "$@" ;;
      list)   shift 2; lit_list   "$@" ;;
      update) shift 2; lit_update "$@" ;;
      *) err "Unknown lit subcommand: '${2:-}'" ;;
    esac ;;
  paper)
    case "${2:-}" in
      list)   shift 2; paper_list   "$@" ;;
      update) shift 2; paper_update "$@" ;;
      *) err "Unknown paper subcommand: '${2:-}'" ;;
    esac ;;
  chapter)
    case "${2:-}" in
      update) shift 2; chapter_update "$@" ;;
      *) err "Unknown chapter subcommand: '${2:-}'" ;;
    esac ;;
  calendar) shift; calendar_show "$@" ;;
  sync)     sync_all ;;
  push)     shift; push_changes "$@" ;;
  help|--help|-h) show_help ;;
  "") show_help ;;
  *) err "Unknown command: '${1}'\nRun 'phd help' for usage." ;;
esac
